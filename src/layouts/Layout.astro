---
import BackgroundAnimation from '../components/BackgroundAnimation.astro';
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="portafolio/favicon.svg" />
		<link rel="icon" href="portafolio/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Marcelo Darras | Portafolio Web</title>
	</head>
	<body class="bg-[#091a16] text-slate-100 antialiased selection:bg-teal-700/40 selection:text-teal-100 min-h-screen relative overflow-x-hidden">
		<BackgroundAnimation />
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}
</style>

